{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "*.ts",
    "*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "lifeBook/**/*.ts",
    "lifeBook/**/*.tsx",
    "revenueForecast/**/*.ts",
    "revenueForecast/**/*.tsx",
    "scripts/**/*.ts",
    "server/**/*.ts",
    "services/**/*.ts",
    "SmoothSailingToday/**/*.ts",
    "SmoothSailingToday/**/*.tsx",
    "valuationOriented/**/*.ts",
    "valuationOriented/**/*.tsx"
  ],
  "exclude": [
    "data",
    "dist",
    "docs",
    "ios",
    "local-domexception",
    "migrated_prompt_history",
    "node_modules",
    "tmp"
  ]
}
