{
  "name": "人生k线/（通用）最新上线版",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:web": "vite build",
    "build": "npm run build:web && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=server-dist/server.cjs",
    "start": "node server-dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "preflight": "tsx scripts/preflight-check.ts",
    "preflight:prod": "tsx scripts/preflight-check.ts --production",
    "test:api": "tsx scripts/api-smoke-test.ts",
    "verify:full": "npm run preflight && npm run lint && npm run test:api && npm run build && npm audit --audit-level=high",
    "db:stats": "tsx scripts/db-maintenance.ts stats",
    "db:backup": "tsx scripts/db-maintenance.ts backup",
    "db:vacuum": "tsx scripts/db-maintenance.ts vacuum",
    "db:purge": "tsx scripts/db-maintenance.ts purge",
    "db:postgres:migrate": "tsx scripts/postgres-migrate.ts",
    "test-user:phone": "tsx scripts/create-test-phone-user.ts",
    "test:sms-registration": "tsx scripts/sms-registration-test.ts",
    "ios:add": "npm run build:web && cap add ios",
    "ios:sync": "npm run build:web && cap sync ios",
    "ios:clean-xattrs": "xattr -cr ios/App/App ios/App/CapApp-SPM || true",
    "ios:open": "cap open ios",
    "ship:ios": "npm run verify:full && npm run ios:sync && npm run ios:clean-xattrs"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.1.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@google/genai": "^1.30.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "argon2": "^0.44.0",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "lucide-react": "^0.555.0",
    "pg": "^8.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-webcam": "^7.2.0",
    "recharts": "^3.5.1",
    "tencentcloud-sdk-nodejs-sms": "^4.1.240",
    "three": "^0.181.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.28.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "overrides": {
    "node-domexception": "file:./local-domexception",
    "form-data": "^4.0.6",
    "protobufjs": "^7.6.3",
    "@babel/core": "^7.29.7"
  }
}
