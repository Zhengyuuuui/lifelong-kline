# Runtime
NODE_ENV=development
# NODE_ENV=production requires APP_ENV=staging or APP_ENV=production.
APP_ENV=sandbox
PORT=3000
# Production with a same-host Nginx proxy should use 127.0.0.1.
HOST=0.0.0.0
PUBLIC_API_BASE_URL=http://127.0.0.1:3000
CLIENT_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,capacitor://localhost,ionic://localhost
CLIENT_CONNECT_SRC=
# For a same-host Nginx proxy use loopback. Keep false without a trusted proxy.
TRUST_PROXY=false
ENABLE_LEGACY_AI_PROXY=false

# PostgreSQL production database
DATABASE_URL=postgres://life_kline:life_kline_password@127.0.0.1:5432/life_kline
DATABASE_SSL=false
PG_POOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=15000
PG_IDLE_TIMEOUT_MS=30000

# Local compatibility database kept for the existing mock/preview backend
SQLITE_PATH=./data/life-kline.sqlite
DATA_RETENTION_DAYS=180

# JWT and session security
JWT_ACCESS_SECRET=replace-with-at-least-32-random-bytes
JWT_REFRESH_SECRET=replace-with-another-32-random-bytes
JWT_ISSUER=life-kline-api
JWT_AUDIENCE=life-kline-ios
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
SESSION_TTL_DAYS=30
API_RATE_LIMIT=240

# Sign in with Apple
APPLE_CLIENT_ID=com.lifekline.destiny
APPLE_BUNDLE_ID=com.lifekline.destiny
APPLE_JWKS_URL=https://appleid.apple.com/auth/keys
APPLE_ISSUER=https://appleid.apple.com

# WeChat OAuth
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_OAUTH_BASE_URL=https://api.weixin.qq.com

# Phone SMS registration
# Local development may use SMS_MODE=mock with a local-only SMS_MOCK_CODE.
# Production must use SMS_MODE=live and real server-only SMS provider
# credentials. Never expose these values through VITE_* variables.
SMS_MODE=disabled
SMS_PROVIDER=tencent
SMS_CODE_HMAC_SECRET=replace-with-at-least-32-random-bytes
SMS_CODE_TTL_SECONDS=300
SMS_CODE_MAX_ATTEMPTS=5
SMS_SEND_COOLDOWN_SECONDS=60
SMS_SEND_IP_LIMIT=20
SMS_SEND_PHONE_LIMIT=5
SMS_SEND_DEVICE_LIMIT=10
SMS_MOCK_CODE=
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_SMS_SDK_APP_ID=
TENCENTCLOUD_SMS_SIGN_NAME=
TENCENTCLOUD_SMS_TEMPLATE_ID=
TENCENTCLOUD_SMS_REGION=ap-guangzhou
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
ALIYUN_DYPNS_REGION=cn-hongkong
ALIYUN_DYPNS_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=100001
ALIYUN_SMS_COUNTRY_CODE=86
ALIYUN_SMS_CODE_PARAM_NAME=code
ALIYUN_SMS_MIN_PARAM_NAME=min

# AI provider keys, model routing and quota
# AI_PROVIDER supports: gemini, openai, openai-compatible, anthropic.
# Use openai-compatible for DeepSeek, Qwen, Kimi, OpenRouter, self-hosted vLLM, etc.
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_API_KEY=
AI_API_BASE_URL=
API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_MODEL=gemini-3.5-flash
AI_FALLBACK_MODELS=gemini-3.1-flash-lite,gemini-flash-latest
AI_TEMPERATURE=0.68
AI_TOP_P=0.9
AI_MAX_OUTPUT_TOKENS=4096
AI_TIMEOUT_MS=45000
AI_CONTRACT_VERSION=life-kline-v1
AI_ALLOW_CLIENT_MODEL_OVERRIDE=false
AI_DISABLE_NATIVE_RESPONSE_FORMAT=false
AI_REQUIRE_AUTH=true
AI_ANON_DAILY_LIMIT=4
AI_FREE_DAILY_LIMIT=20
AI_MEMBER_DAILY_LIMIT=500
AI_REQUEST_WINDOW_MS=86400000

# Apple IAP / payments
PAYMENTS_MODE=mock
PAYMENTS_PROVIDER=xunhupay
APPLE_IAP_ENV=sandbox
APPLE_IAP_PRODUCT_IDS=com.lifekline.monthly,com.lifekline.yearly,com.lifekline.lifetime
APPLE_APP_APPLE_ID=
APPLE_ROOT_CERTIFICATE_PATHS=
APPLE_ROOT_CERTIFICATES_PEM=
APPLE_SIGNED_DATA_ONLINE_CHECKS=true
APPLE_VERIFY_RECEIPT_SANDBOX_URL=https://sandbox.itunes.apple.com/verifyReceipt
APPLE_VERIFY_RECEIPT_PRODUCTION_URL=https://buy.itunes.apple.com/verifyReceipt
APPLE_SHARED_SECRET=
APPLE_APP_STORE_SERVER_API_ISSUER_ID=
APPLE_APP_STORE_SERVER_API_KEY_ID=
APPLE_APP_STORE_SERVER_API_PRIVATE_KEY=

# Xunhupay web payments
# Keep PAYMENTS_MODE=mock for local development. Production requires live mode,
# real server-only credentials, and public HTTPS URLs. Never expose these values
# through VITE_* variables or commit populated secrets.
PUBLIC_SITE_URL=
XUNHUPAY_APP_ID=
XUNHUPAY_SECRET=
XUNHUPAY_GATEWAY=https://api.xunhupay.com/payment/do.html
XUNHUPAY_GATEWAY_BACKUP=https://api.dpweixin.com/payment/do.html
XUNHUPAY_NOTIFY_URL=
XUNHUPAY_RETURN_URL=
XUNHUPAY_CALLBACK_URL=

# Cross-instance Postgres rate limiting for production auth/payment/AI routes
PG_RATE_LIMIT_ENABLED=true

# iOS / remote API
VITE_API_BASE_URL=
VITE_ENABLE_LEGACY_AI_PROXY=false
VITE_ALLOW_LOCAL_PREMIUM_FALLBACK=false
VITE_APPLE_IAP_MONTHLY_PRODUCT_ID=com.lifekline.monthly
VITE_APPLE_IAP_LIFETIME_PRODUCT_ID=com.lifekline.lifetime
CAPACITOR_SERVER_URL=
